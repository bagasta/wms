# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
DATABASE_URL="postgresql://postgres:password@localhost:5432/whatsapp_management"

# JWT Secret
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=1d

# WhatsApp WebJS Configuration
WWEBJS_DATA_DIR=.wwebjs_auth

# Webhook Configuration
# WEBHOOK_TIMEOUT_MS=10000
# WEBHOOK_SLOW_RESPONSE_MS=9000
# WEBHOOK_REJECT_UNAUTHORIZED=true
